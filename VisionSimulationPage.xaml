<Page x:Class="Colorblind_Asisstant.VisionSimulationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="16,12">
        <!-- Navigation Back Button -->
        <Button Content="← Color Reading Page" 
                Width="180"
                Height="35"
                FontSize="12"
                FontWeight="SemiBold"
                Background="#4A4A4A"
                Foreground="#FFFFFF"
                BorderThickness="0"
                HorizontalAlignment="Left"
                Click="GoBackToColorReading_Click" />
        
        <TextBlock x:Name="VisionModeTitle"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Text="Vision Simulation Settings"
                   Margin="0,16,0,8"
                   Foreground="#FFFFFF" />
        
        <!-- Vision Mode Toggle Buttons -->
        <Border CornerRadius="8" 
                Background="#2A2A2A"
                BorderBrush="#3A3A3A"
                BorderThickness="1"
                Margin="0,8">
            <StackPanel>
                <TextBlock Text="Select Color Vision Mode"
                           FontSize="14"
                           FontWeight="Medium"
                           Foreground="#AAAAAA"
                           Margin="0,12,0,8" />
                
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <!-- Normal/Normal View Button -->
                    <Border x:Name="NormalModeButton"
                            Width="140"
                            Height="50"
                            CornerRadius="6"
                            Background="#2E8B57"
                            BorderThickness="0"
                            Click="ToggleVisionMode_Click">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="👁️ Normal"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFFF" />
                            <TextBlock Text="Standard Vision"
                                       FontSize="9"
                                       Foreground="#CCCCCC" />
                        </StackPanel>
                    </Border>
                    
                    <!-- Protanopia/Red-Blind Button -->
                    <Border x:Name="ProtanopiaButton"
                            Width="140"
                            Height="50"
                            CornerRadius="6"
                            Background="#3A3A3A"
                            BorderThickness="0"
                            Click="ToggleVisionMode_Click">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="👁️ Protanopia"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFFF" />
                            <TextBlock Text="Simulated Red-Blindness"
                                       FontSize="9"
                                       Foreground="#CCCCCC" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Current Mode Display -->
        <TextBlock x:Name="CurrentModeText"
                   FontSize="16"
                   FontWeight="Bold"
                   Text="Current: Normal Vision"
                   Margin="0,8,0,4"
                   Foreground="#FFFFFF" />
        
        <!-- Status Display -->
        <Border CornerRadius="8" 
                Background="#2A2A2A"
                BorderBrush="#3A3A3A"
                BorderThickness="1"
                Margin="0,8">
            <StackPanel>
                <TextBlock Text="Vision Simulation Status:"
                           FontSize="14"
                           FontWeight="Medium"
                           Foreground="#AAAAAA"
                           Margin="0,12,0,8" />
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Mode Label -->
                    <TextBlock x:Name="ModeStatusLabel"
                               Grid.Row="0"
                               FontSize="13"
                               Text="Vision Simulation: OFF"
                               Foreground="#FFFFFF" />
                    
                    <!-- Test Instructions -->
                    <Border Grid.Row="1" 
                            CornerRadius="4" 
                            Padding="8,6"
                            Background="#1A1A1A"
                            Margin="0,4">
                        <TextBlock x:Name="TestInstructions"
                                   FontSize="11"
                                   Foreground="#999999"
                                   TextWrapping="Wrap"
                                   LineHeight="1.5">
                            👀 Hover over any color in your browser or app to test how Protanopia changes the colors you see!
                        </TextBlock>
                    </Border>
                    
                    <!-- LMS Matrix Info -->
                    <Border Grid.Row="2" 
                            CornerRadius="4" 
                            Padding="8,6"
                            Background="#1A1A1A"
                            Margin="0,4">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="LMS Matrix:" FontSize="11" Foreground="#999999"/>
                            <TextBlock x:Name="MatrixInfoText"
                                       FontSize="11"
                                       Foreground="#00FF00"
                                       TextWrapping="Wrap">
                                Protanopia simulated using LMS cone transformation matrix for red-blindness color perception
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Information Section -->
        <Border CornerRadius="8" 
                Background="#2A2A2A"
                BorderBrush="#3A3A3A"
                BorderThickness="1"
                Margin="0,8">
            <StackPanel>
                <TextBlock Text="About Protanopia:"
                           FontSize="14"
                           FontWeight="Medium"
                           Foreground="#AAAAAA"
                           Margin="0,12,0,8" />
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- What is Protanopia -->
                    <Border Grid.Row="0" 
                            CornerRadius="4" 
                            Padding="8,6"
                            Background="#1A1A1A">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔴" FontSize="12" Foreground="#FF4444"/>
                            <TextBlock x:Name="ProtanopiaInfoText"
                                       FontSize="11"
                                       Foreground="#999999"
                                       TextWrapping="Wrap">
                                A form of colorblindness where red cone cells (L-cones) don't function normally. Red and green colors appear more similar, making it difficult to distinguish red-green combinations.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- Who has it -->
                    <Border Grid.Row="1" 
                            CornerRadius="4" 
                            Padding="8,6"
                            Background="#1A1A1A">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" FontSize="12" Foreground="#FFAA00"/>
                            <TextBlock x:Name="ProtanopiaUsersText"
                                       FontSize="11"
                                       Foreground="#999999"
                                       TextWrapping="Wrap">
                                Affects approximately 8% of men and 0.5% of women (X-linked trait). Also called 'red-blindness'.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- How this helps -->
                    <Border Grid.Row="2" 
                            CornerRadius="4" 
                            Padding="8,6"
                            Background="#1A1A1A">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✅" FontSize="12" Foreground="#00FF00"/>
                            <TextBlock x:Name="HelperInfoText"
                                       FontSize="11"
                                       Foreground="#999999"
                                       TextWrapping="Wrap">
                                This simulation applies an LMS transformation matrix to approximate how red-blindness affects color perception. Great for accessibility testing and inclusive design!
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Technical Info (Advanced) -->
        <Button Content="🔧 Advanced: View LMS Matrix Details" 
                Width="180"
                Height="32"
                FontSize="11"
                FontWeight="Light"
                Background="#3A3A3A"
                Foreground="#999999"
                BorderThickness="0"
                Click="ShowLMSMatrix_Click"
                HorizontalAlignment="Left" />

    </StackPanel>
</Page>
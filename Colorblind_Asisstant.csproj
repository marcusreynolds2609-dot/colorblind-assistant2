<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <UseAppHost>true</UseAppHost>
    <AssemblyTitle>Colorblind Assistant</AssemblyTitle>
    <Product>Colorblind Assistant</Product>
    <Description>Accessible Windows overlay that identifies on-screen colors in real time.</Description>
    <Company>Colorblind Assistant Contributors</Company>
    <Authors>Colorblind Assistant Contributors</Authors>
    <Version>0.1.0</Version>
    <AssemblyVersion>0.1.0.0</AssemblyVersion>
    <FileVersion>0.1.0.0</FileVersion>
    <RepositoryUrl>https://github.com/your-username/colorblind-assistant</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

</Project>
